{
  "expo": {
    "name": "ScanIntent",
    "slug": "zerotype",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "scanintent",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F7FA"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.scanintent.app",
      "infoPlist": {
        "NSCameraUsageDescription": "ScanIntent uses your camera to capture text from physical documents, business cards, and banners.",
        "NSPhotoLibraryUsageDescription": "ScanIntent accesses your photo library to scan images for text.",
        "NSContactsUsageDescription": "ScanIntent saves detected contact information directly to your phone contacts.",
        "NSFaceIDUsageDescription": "ScanIntent uses Face ID to protect your scan history vault."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#F5F7FA"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.scanintent.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-sqlite",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow ScanIntent to access your camera"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow ScanIntent to use Face ID to protect your history."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "64ed5e0a-1f38-4158-96c8-bab93ef9cf6c"
      }
    },
    "owner": "sudosayak"
  }
}
